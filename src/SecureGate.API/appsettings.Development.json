{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Issuer": "https://securegate.local",
    "Audience": "securegate-api",
    "KeyId": "dev-signing-key",
    "AccessTokenLifetimeMinutes": 15,
    "IdTokenLifetimeMinutes": 60
  },

  "RefreshToken": {
    "LifetimeDays": 30
  },

  "AzureAdB2C": {
    "Instance": "https://YOUR-TENANT.b2clogin.com",
    "ClientId": "YOUR-B2C-CLIENT-ID",
    "Domain": "YOUR-TENANT.onmicrosoft.com",
    "SignUpSignInPolicyId": "B2C_1_SignUpSignIn",
    "ResetPasswordPolicyId": "B2C_1_PasswordReset",
    "EditProfilePolicyId": "B2C_1_EditProfile"
  },

  "KeyVault": {
    "Uri": "https://YOUR-KEYVAULT.vault.azure.net/",
    "Enabled": false
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SecureGate;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://localhost:5001"
    ]
  },

  "DemoTenant": {
    "TenantId": "demo",
    "TenantName": "Demo Tenant",
    "Domain": "demo.securegate.local",
    "Clients": [
      {
        "ClientId": "demo-spa",
        "ClientName": "Demo SPA Application",
        "IsPublicClient": true,
        "RedirectUris": [
          "http://localhost:3000/callback",
          "http://localhost:5173/callback",
          "https://localhost:5001/callback"
        ]
      }
    ]
  }
}
